# Database Configuration
POSTGRES_USER=smartplant
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=smartplant_db
DATABASE_URL=postgresql://smartplant:your_secure_password@db:5432/smartplant_db

# MQTT Configuration
MQTT_BROKER=mqtt
MQTT_PORT=1883
MQTT_TOPIC_SENSOR=smartplant/sensors
MQTT_TOPIC_CONTROL=smartplant/control

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Backend Configuration
BACKEND_PORT=8000
API_PREFIX=/api/v1

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000/api/v1

# ESP32 Configuration (for reference)
WIFI_SSID=your_wifi_ssid
WIFI_PASSWORD=your_wifi_password
