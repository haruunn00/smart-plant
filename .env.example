# Database Configuration
POSTGRES_USER=smartplant
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=smartplant_db
DATABASE_URL=postgresql://smartplant:your_secure_password_here@db:5432/smartplant_db

# MQTT Configuration
MQTT_BROKER=mqtt
MQTT_PORT=1883
MQTT_TOPIC_SENSOR=smartplant/sensors
MQTT_TOPIC_CONTROL=smartplant/control

# OpenAI Configuration
OPENAI_API_KEY=sk-your_openai_api_key_here

# Backend Configuration
BACKEND_PORT=8000
API_PREFIX=/api/v1

# CORS Configuration (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ESP32 Configuration (for reference - set these in config.h)
# WIFI_SSID=your_wifi_ssid
# WIFI_PASSWORD=your_wifi_password
# MQTT_BROKER_IP=192.168.1.100
